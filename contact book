contacts = {}

while True:
    print("1.Add Contact\n2.View Contacts\n3.Search\n4.Exit")
    ch = input("Choice: ")

    if ch == "1":
        name = input("Name: ")
        phone = input("Phone: ")
        contacts[name] = phone

    elif ch == "2":
        print(contacts)

    elif ch == "3":
        name = input("Enter name: ")
        print(contacts.get(name, "Not found"))

    else:
        break
